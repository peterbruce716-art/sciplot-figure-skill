{
  "schema": "scientificfigure.plot_policy.v1",
  "policy_version": "1.0",
  "policies": [
    {"policy_id": "small_sample_mean_only", "severity": "warning", "enabled": true, "when": [{"field": "sample.min_group_n", "operator": "lt", "value": 10}, {"field": "chart.type", "operator": "in", "value": ["bar", "mean_bar", "grouped_bar"]}, {"field": "chart.raw_points_visible", "operator": "eq", "value": false}], "message": "小样本均值柱可能掩盖原始分布。", "recommended_actions": ["overlay_raw_points", "use_stripplot", "declare_error_bar_semantics"]},
    {"policy_id": "undefined_error_semantics", "severity": "warning", "enabled": true, "when": [{"field": "chart.has_uncertainty", "operator": "eq", "value": true}, {"field": "intent.uncertainty_semantics", "operator": "missing", "value": true}], "message": "误差棒或误差带的统计语义未声明。", "recommended_actions": ["declare_sd_sem_ci", "add_n_to_caption"]},
    {"policy_id": "dual_y_axis", "severity": "warning", "enabled": true, "when": [{"field": "chart.dual_y", "operator": "eq", "value": true}], "message": "双 Y 轴容易制造不可比的视觉关联。", "recommended_actions": ["split_panels", "standardize_units"]},
    {"policy_id": "pie_many_categories", "severity": "warning", "enabled": true, "when": [{"field": "chart.type", "operator": "in", "value": ["pie", "pie_chart"]}, {"field": "data.category_count", "operator": "gt", "value": 5}], "message": "类别过多时饼图难以准确比较。", "recommended_actions": ["use_sorted_horizontal_bar"]},
    {"policy_id": "unnecessary_3d", "severity": "warning", "enabled": true, "when": [{"field": "chart.is_3d", "operator": "eq", "value": true}], "message": "3D 透视会降低数值比较准确性。", "recommended_actions": ["use_2d_projection", "use_small_multiples"]},
    {"policy_id": "truncated_y_axis", "severity": "warning", "enabled": true, "when": [{"field": "axis.y_truncated", "operator": "eq", "value": true}, {"field": "axis.y_break_declared", "operator": "eq", "value": false}], "message": "截断 Y 轴但未声明可能夸大差异。", "recommended_actions": ["start_at_zero", "declare_axis_break"]},
    {"policy_id": "red_green_palette", "severity": "warning", "enabled": true, "when": [{"field": "style.uses_red_green_only", "operator": "eq", "value": true}], "message": "仅用红绿区分数据对色觉缺陷不友好。", "recommended_actions": ["use_okabe_ito", "add_line_style_or_marker"]},
    {"policy_id": "rainbow_colormap", "severity": "warning", "enabled": true, "when": [{"field": "style.colormap", "operator": "in", "value": ["rainbow", "jet"]}], "message": "rainbow/jet 的感知亮度不均匀。", "recommended_actions": ["use_viridis", "use_diverging_map_for_signed_data"]},
    {"policy_id": "legend_overcrowded", "severity": "warning", "enabled": true, "when": [{"field": "style.legend_count", "operator": "gt", "value": 12}], "message": "图例条目过多会增加认知负担。", "recommended_actions": ["split_panels", "direct_label_series"]},
    {"policy_id": "missing_panel_labels", "severity": "warning", "enabled": true, "when": [{"field": "layout.panel_count", "operator": "gt", "value": 1}, {"field": "layout.panel_labels_present", "operator": "eq", "value": false}], "message": "多面板图缺少明确的面板编号。", "recommended_actions": ["add_panel_labels"]},
    {"policy_id": "missing_glyphs", "severity": "error", "enabled": true, "when": [{"field": "font.missing_glyphs", "operator": "gt", "value": 0}], "message": "字体缺字会破坏可读性。", "recommended_actions": ["resolve_cjk_font", "rerender_with_font_qa"]},
    {"policy_id": "text_clipping", "severity": "error", "enabled": true, "when": [{"field": "layout.text_clipped", "operator": "eq", "value": true}], "message": "文字被裁切，必须在脚本中修复布局。", "recommended_actions": ["adjust_margins", "rerender"]},
    {"policy_id": "tick_overlap", "severity": "warning", "enabled": true, "when": [{"field": "layout.tick_labels_overlap", "operator": "eq", "value": true}], "message": "刻度标签重叠会降低读数可靠性。", "recommended_actions": ["rotate_ticks", "reduce_tick_density"]},
    {"policy_id": "unexplained_significance", "severity": "warning", "enabled": true, "when": [{"field": "annotation.significance_present", "operator": "eq", "value": true}, {"field": "annotation.test_declared", "operator": "eq", "value": false}], "message": "显著性标记缺少检验方法和多重校正说明。", "recommended_actions": ["declare_test", "declare_correction"]},
    {"policy_id": "continuous_as_category", "severity": "warning", "enabled": true, "when": [{"field": "data.x_numeric", "operator": "eq", "value": true}, {"field": "data.x_treated_as_category", "operator": "eq", "value": true}], "message": "连续变量被当作类别处理，可能丢失趋势信息。", "recommended_actions": ["use_scatter_or_line", "document_discretization"]},
    {"policy_id": "inconsistent_panel_scales", "severity": "warning", "enabled": true, "when": [{"field": "layout.panel_count", "operator": "gt", "value": 1}, {"field": "layout.shared_scale_required", "operator": "eq", "value": true}, {"field": "layout.scales_consistent", "operator": "eq", "value": false}], "message": "多面板尺度不一致会妨碍跨面板比较。", "recommended_actions": ["share_axis_limits", "declare_independent_scales"]},
    {"policy_id": "raw_points_hidden", "severity": "warning", "enabled": true, "when": [{"field": "sample.min_group_n", "operator": "lt", "value": 20}, {"field": "chart.raw_points_visible", "operator": "eq", "value": false}], "message": "小到中等样本中完全隐藏原始点会削弱分布透明度。", "recommended_actions": ["overlay_raw_points"]},
    {"policy_id": "sample_size_undisclosed", "severity": "warning", "enabled": true, "when": [{"field": "caption.sample_size_declared", "operator": "eq", "value": false}], "message": "图注或机器可读元数据未声明样本量。", "recommended_actions": ["add_n_to_caption", "record_group_counts"]}
  ]
}
