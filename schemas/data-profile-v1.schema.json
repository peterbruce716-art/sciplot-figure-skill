{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scientificfigure.data_profile.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "source", "row_count", "columns", "group_statistics", "distribution", "warnings", "recommended_tasks"],
  "properties": {
    "schema": {"const": "scientificfigure.data_profile.v1"},
    "schema_version": {"const": "1.0"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "sheet": {"type": ["string", "integer", "null"]}
      }
    },
    "row_count": {"type": "integer", "minimum": 0},
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "inferred_type", "missing_count", "unique_count", "suspected_id"],
        "properties": {
          "name": {"type": "string"},
          "inferred_type": {"enum": ["continuous", "ordinal", "categorical", "datetime", "boolean", "text", "unknown"]},
          "missing_count": {"type": "integer", "minimum": 0},
          "unique_count": {"type": "integer", "minimum": 0},
          "suspected_id": {"type": "boolean"},
          "uncertainty_candidate": {"type": "boolean"},
          "uncertainty_evidence": {"$ref": "#/$defs/uncertainty_evidence"}
        }
      }
    },
    "group_statistics": {"type": "array", "items": {"type": "object"}},
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skewness", "outliers"],
      "properties": {
        "skewness": {"type": "object", "additionalProperties": {"type": ["number", "null"]}},
        "outliers": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
      }
    },
    "warnings": {"type": "array", "items": {"$ref": "#/$defs/message"}},
    "recommended_tasks": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "uncertainty_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "explicit_uncertainty_columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "uncertainty_evidence": {"type": "array", "items": {"$ref": "#/$defs/uncertainty_evidence"}},
    "repeated_x": {"type": ["object", "null"], "additionalProperties": false, "properties": {
      "x": {"type": "string"},
      "unique_x": {"type": "integer", "minimum": 0},
      "max_replicates_per_x": {"type": "integer", "minimum": 0},
      "repeated_x_count": {"type": "integer", "minimum": 0},
      "has_repeated_observations": {"type": "boolean"}
    }}
  },
  "$defs": {
    "uncertainty_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "match_type", "confidence"],
      "properties": {
        "column": {"type": "string"},
        "is_uncertainty": {"type": "boolean"},
        "source": {"enum": ["explicit", "name_inference", "metadata"]},
        "match_type": {"type": "string"},
        "matched_token": {"type": ["string", "null"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "semantics": {"type": ["string", "null"]}
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": {"type": "string"},
        "severity": {"enum": ["info", "warning", "error"]},
        "message": {"type": "string"},
        "columns": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
