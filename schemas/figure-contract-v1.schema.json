{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scientificfigure.figure_contract.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "scientific_question",
    "core_claim",
    "target_audience",
    "target_journal",
    "target_width_mm",
    "archetype",
    "evidence_chain",
    "panel_plan",
    "assumptions",
    "approval"
  ],
  "properties": {
    "schema": {"const": "scientificfigure.figure_contract.v1"},
    "schema_version": {"const": "1.0"},
    "scientific_question": {"type": "string", "minLength": 1},
    "core_claim": {"type": "string"},
    "target_audience": {"type": "string", "minLength": 1},
    "target_journal": {"type": "string", "minLength": 1},
    "target_width_mm": {"type": "number", "exclusiveMinimum": 0},
    "archetype": {
      "enum": ["quantitative_grid", "schematic_led", "image_quant", "asymmetric_mixed"]
    },
    "hero_panel_id": {"type": ["string", "null"]},
    "evidence_chain": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"},
      "uniqueItems": true
    },
    "panel_plan": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/panel"}
    },
    "assumptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/assumption"}
    },
    "approval": {"$ref": "#/$defs/approval"},
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "claim", "status"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "claim": {"type": "string"},
        "status": {"enum": ["declared", "inferred", "unknown", "not_applicable"]},
        "provenance": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["panel_id", "scientific_role", "question", "preferred_representation", "evidence_ids"],
      "properties": {
        "panel_id": {"type": "string", "minLength": 1},
        "scientific_role": {
          "enum": ["context", "hero", "evidence", "quantification", "mechanism", "validation", "supporting"]
        },
        "question": {"type": "string", "minLength": 1},
        "preferred_representation": {"type": "string", "minLength": 1},
        "evidence_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "panel_weight": {"type": "number", "exclusiveMinimum": 0},
        "backend": {"enum": ["matplotlib", "r", "project", "unknown"]},
        "required_output": {"enum": ["svg", "pdf", "png", "mixed", "unknown"]}
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "reason", "status"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "status": {"enum": ["inferred", "user_declared", "defaulted", "unknown"]}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "status"],
      "properties": {
        "mode": {"enum": ["auto", "interactive", "strict"]},
        "status": {"enum": ["not_required", "pending", "approved", "rejected"]}
      }
    }
  }
}
