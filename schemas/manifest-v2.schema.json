{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scientificfigure.manifest.v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "figures", "per_figure_scripts"],
  "properties": {
    "schema": {"const": "scientificfigure.manifest.v2"},
    "project_root": {"type": "string"},
    "spec_path": {"type": "string"},
    "output_dir": {"type": "string"},
    "runner": {"type": "string"},
    "backend": {"type": "string"},
    "crop_mode": {"type": "string"},
    "resolved_fonts": {"type": "object", "additionalProperties": true},
    "exports": {"$ref": "#/$defs/exports"},
    "status": {"$ref": "#/$defs/final_status"},
    "overall_status": {"enum": ["strict_pass", "pass", "near_pass", "render_only", "not_strict", "not_applicable", "failed", "incomplete"]},
    "run_status": {"enum": ["not_run", "completed", "failed"]},
    "qa_execution_status": {"enum": ["not_run", "completed", "failed"]},
    "quality_status": {"enum": ["strict_pass", "validated_pass", "near_pass", "render_only", "not_strict", "not_applicable", "failed"]},
    "source_code_status": {"type": "string"},
    "render_status": {"type": "string"},
    "raster_export_status": {"type": "string"},
    "vector_export_status": {"type": "string"},
    "export_status": {"type": "string"},
    "vector_validation_status": {"type": "string"},
    "canvas_safety_status": {"enum": ["pass", "failed"]},
    "boxed_text_safety_status": {"enum": ["pass", "failed"]},
    "plot_geometry_safety_status": {"enum": ["pass", "failed"]},
    "semantic_reconstruction_status": {"type": "string"},
    "visual_qa_status": {"type": "string"},
    "qa_status": {"type": "string"},
    "semantic_audit": {"type": "object", "additionalProperties": true},
    "vector_validation": {"type": "object", "additionalProperties": true},
    "canvas_safety": {"$ref": "#/$defs/canvas_safety_report"},
    "boxed_text_safety": {"$ref": "#/$defs/boxed_text_safety_report"},
    "plot_geometry_safety": {"$ref": "#/$defs/plot_geometry_safety_report"},
    "checksums": {"type": "string"},
    "semantics": {"type": "string"},
    "source_strategy": {
      "enum": ["raw_data", "digitized_raster", "manual_measurement", "vector_redraw", "color_region_extraction", "pixel_trace", "mixed"]
    },
    "representation": {
      "enum": ["semantic_vector", "semantic_raster", "mixed", "pixel_primitives"]
    },
    "figures": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/figure_record"}
    },
    "per_figure_scripts": {
      "type": "object",
      "additionalProperties": {"type": ["string", "null"]}
    },
    "errors": {"type": "array"}
    ,
    "notes": {"type": "array"},
    "companion_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["path", "sha256", "schema"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string"},
          "schema": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "plot_geometry_safety_report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "status"],
      "properties": {
        "schema": {"const": "scientificfigure.plot_geometry_safety.v1"},
        "status": {"enum": ["pass", "failed"]},
        "image": {"type": "string"},
        "failed_regions": {"type": "array", "items": {"type": "string"}},
        "regions": {"type": "array", "items": {"type": "object"}}
      }
    },
    "boxed_text_safety_report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "status"],
      "properties": {
        "schema": {"const": "scientificfigure.boxed_text_safety.v1"},
        "status": {"enum": ["pass", "failed"]},
        "image": {"type": "string"},
        "failed_regions": {"type": "array", "items": {"type": "string"}},
        "regions": {"type": "array", "items": {"type": "object"}}
      }
    },
    "canvas_safety_report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "status"],
      "properties": {
        "schema": {"const": "scientificfigure.canvas_safety.v1"},
        "status": {"enum": ["pass", "failed"]},
        "image": {"type": "string"},
        "margin_px": {"type": "integer", "minimum": 1},
        "required_edges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["top", "right", "bottom", "left"]}
        },
        "failed_edges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["top", "right", "bottom", "left"]}
        }
      }
    },
    "final_status": {
      "enum": ["semantic_strict_pass", "semantic_validated_pass", "semantic_near_pass", "visual_trace_pass", "render_only", "not_strict", "failed"]
    },
    "exports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["png", "svg", "pdf"],
      "properties": {
        "png": {"type": "string"},
        "svg": {"type": "string"},
        "pdf": {"type": "string"}
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": true,
      "required": ["execution_status", "result"],
      "properties": {
        "execution_status": {"enum": ["not_run", "completed", "failed"]},
        "result": {"enum": ["strict_pass", "validated_pass", "near_pass", "not_strict", "not_applicable"]},
        "profile": {"enum": ["semantic", "visual", "trace"]},
        "score_report": {"type": ["string", "null"]},
        "score": {"type": "object"}
      }
    },
    "panel_record": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bbox_normalized": {"type": "array"},
        "source": {"type": ["string", "null"]},
        "source_strategy": {"type": "string"},
        "representation": {"type": "string"},
        "qa": {"$ref": "#/$defs/qa"}
      }
    },
    "figure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exports", "qa", "status"],
      "properties": {
        "source": {"type": ["string", "null"]},
        "script": {"type": ["string", "null"]},
        "runner": {"type": ["string", "null"]},
        "spec": {"type": ["string", "null"]},
        "source_strategy": {
          "enum": ["raw_data", "digitized_raster", "manual_measurement", "vector_redraw", "color_region_extraction", "pixel_trace", "mixed"]
        },
        "representation": {
          "enum": ["semantic_vector", "semantic_raster", "mixed", "pixel_primitives"]
        },
        "status": {"$ref": "#/$defs/final_status"},
        "exports": {"$ref": "#/$defs/exports"},
        "qa": {"$ref": "#/$defs/qa"},
        "score": {"type": "object"},
        "panels": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/panel_record"}
        },
        "png": {"type": "string"},
        "svg": {"type": "string"},
        "pdf": {"type": "string"},
        "deviation": {"type": "string"}
      }
    }
  }
}
