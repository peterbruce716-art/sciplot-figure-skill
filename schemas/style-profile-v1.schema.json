    "checked_date": {"type": "string", "format": "date"},
    "scope": {"type": "string"},
    "settings": {"type": "object", "additionalProperties": true},
    "user_overrides": {"type": "object", "additionalProperties": true},
    "disclaimer": {"type": "string"}
  }
}
